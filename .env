# Пример файла .env для Telegram Message Sender
# =============================================
# Скопируйте этот файл в .env и заполните своими данными:
# cp .env.example .env

# API ID от Telegram (получите на https://my.telegram.org/apps)
TELEGRAM_API_ID=12345678

# API Hash от Telegram (получите на https://my.telegram.org/apps)
TELEGRAM_API_HASH=bcdef1234567890abcdef1234567890

# Номер телефона в международном формате
TELEGRAM_PHONE=+37499123456
